---
import { Icon } from 'astro-icon/components';

interface Tech {
  name: string;
  icon: string;
  link: string;
}

/**
 * One "See more" per experience card (entire bullet list or details block), not per bullet.
 * Show toggle when there are several bullets or the combined text is long.
 */
const CARD_EXPAND_MIN_BULLETS = 2;
const CARD_EXPAND_MIN_CHARS = 90;
const DETAILS_EXPAND_MIN_CHARS = 75;

const {
  cardIndex = 0,
  title,
  sub_title,
  years,
  details,
  bullets,
  company_link,
  company_icon,
  company_logo_url,
  technologies = [],
  duration,
  country,
  work_mode,
} = Astro.props as {
  cardIndex?: number;
  title: string;
  sub_title: string;
  years: string;
  details?: string;
  bullets?: string[];
  company_link?: string;
  company_icon?: string;
  company_logo_url?: string;
  technologies?: Tech[];
  duration?: string;
  country?: string;
  work_mode?: string;
};

const companyMeta = [duration, country, work_mode].filter(Boolean).join(' · ');
const hasCompanyMeta = companyMeta.length > 0;

function companyInitials(name: string): string {
  const tokens = name
    .replace(/[()]/g, ' ')
    .split(/[^A-Za-zğüşıöçĞÜŞİÖÇ0-9]+/)
    .filter((t) => t.length > 0);
  if (tokens.length >= 2) {
    return (tokens[0][0] + tokens[1][0]).toUpperCase();
  }
  return name.slice(0, 2).toUpperCase();
}

const bulletItems = bullets?.filter(Boolean) ?? [];
const hasBullets = bulletItems.length > 0;
const bulletBodyChars = bulletItems.reduce((sum, line) => sum + line.length, 0);
const needsExperienceExpand =
  hasBullets &&
  (bulletItems.length >= CARD_EXPAND_MIN_BULLETS || bulletBodyChars >= CARD_EXPAND_MIN_CHARS);
const needsDetailsExpandBlock =
  Boolean(details && details.length >= DETAILS_EXPAND_MIN_CHARS);
const techList = technologies ?? [];
const useCompanyBlock =
  hasBullets ||
  Boolean(company_link) ||
  Boolean(company_icon) ||
  Boolean(company_logo_url) ||
  techList.length > 0;

const initials = companyInitials(sub_title);
---

<li class="p-5 bg-background-offset shadow-lg rounded-xl border border-default">
  <div class="flex flex-col sm:flex-row justify-between items-start gap-2">
    <div class="mb-1 sm:mb-0 min-w-0">
      <h3 class="text-2xl font-semibold">{title}</h3>
    </div>
    <p class="text-sm text-offset sm:text-right whitespace-nowrap shrink-0">{years}</p>
  </div>

  {
    useCompanyBlock ? (
      <>
        <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-2">
          {company_link ? (
            <a
              href={company_link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2.5 min-w-0 rounded-md w-fit group focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              <span
                class:list={[
                  'h-9 w-9 shrink-0 overflow-hidden rounded-lg border border-default bg-[#FDFDFC]',
                  company_logo_url ? 'flex items-center justify-center p-0.5' : 'block',
                ]}
              >
                {company_logo_url ? (
                  <img
                    src={company_logo_url}
                    alt=""
                    width="36"
                    height="36"
                    loading="lazy"
                    decoding="async"
                    class="max-h-full max-w-full object-contain object-center"
                  />
                ) : company_icon ? (
                  <Icon
                    name={company_icon}
                    class="block h-full w-full text-offset [&_svg]:block [&_svg]:h-full [&_svg]:w-full [&_svg]:object-cover"
                    aria-hidden="true"
                  />
                ) : (
                  <span class="flex h-full w-full items-center justify-center bg-default/40 text-xs font-bold tracking-tight text-primary">
                    {initials}
                  </span>
                )}
              </span>
              <span class="flex min-w-0 flex-col gap-0.5">
                <span class="text-lg font-medium text-secondary group-hover:text-primary transition-colors break-words">
                  {sub_title}
                </span>
                {hasCompanyMeta ? (
                  <span class="text-sm font-normal text-offset leading-snug">{companyMeta}</span>
                ) : null}
              </span>
            </a>
          ) : (
            <div class="inline-flex items-center gap-2.5 min-w-0">
              <span
                class:list={[
                  'h-9 w-9 shrink-0 overflow-hidden rounded-lg border border-default bg-[#FDFDFC]',
                  company_logo_url ? 'flex items-center justify-center p-0.5' : 'block',
                ]}
              >
                {company_logo_url ? (
                  <img
                    src={company_logo_url}
                    alt=""
                    width="36"
                    height="36"
                    loading="lazy"
                    decoding="async"
                    class="max-h-full max-w-full object-contain object-center"
                  />
                ) : company_icon ? (
                  <Icon
                    name={company_icon}
                    class="block h-full w-full text-offset [&_svg]:block [&_svg]:h-full [&_svg]:w-full [&_svg]:object-cover"
                    aria-hidden="true"
                  />
                ) : (
                  <span class="flex h-full w-full items-center justify-center bg-default/40 text-xs font-bold tracking-tight text-primary">
                    {initials}
                  </span>
                )}
              </span>
              <span class="flex min-w-0 flex-col gap-0.5">
                <span class="text-lg font-medium text-secondary break-words">{sub_title}</span>
                {hasCompanyMeta ? (
                  <span class="text-sm font-normal text-offset leading-snug">{companyMeta}</span>
                ) : null}
              </span>
            </div>
          )}
        </div>

        {techList.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-3" aria-label="Technologies used">
            {techList.map((tech) => (
              <li>
                <a
                  href={tech.link}
                  title={tech.name}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex h-9 w-9 items-center justify-center rounded-lg border border-default bg-background/60 text-offset hover:text-primary hover:border-primary/50 transition-colors"
                >
                  <Icon name={tech.icon} class="h-5 w-5" aria-hidden="true" />
                  <span class="sr-only">{tech.name}</span>
                </a>
              </li>
            ))}
          </ul>
        )}

        {hasBullets ? (
          needsExperienceExpand ? (
            <div class="portfolio-card-expand mt-4">
              <input
                type="checkbox"
                id={`portfolio-card-${cardIndex}`}
                class="portfolio-card-expand-input peer sr-only"
              />
              <div class="portfolio-card-expand-shell relative">
                <div class="portfolio-card-expand-inner overflow-hidden max-h-[6rem] sm:max-h-[6.75rem] transition-[max-height] duration-300 ease-out">
                  <ul class="space-y-2.5 text-offset leading-relaxed list-disc pl-5 marker:text-primary">
                    {bulletItems.map((line) => (
                      <li>{line}</li>
                    ))}
                  </ul>
                </div>
                <div
                  class="portfolio-card-expand-fade pointer-events-none absolute inset-x-0 bottom-0 z-10 h-[4.5rem] sm:h-20 transition-opacity duration-200"
                  aria-hidden="true"
                >
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-[var(--color-background-offset)] from-[8%] via-[var(--color-background-offset)]/95 to-transparent"
                  />
                  <span
                    class="relative flex h-full items-end justify-center pb-1 text-xs leading-none text-primary/50"
                  >
                    ⌄
                  </span>
                </div>
              </div>
              <label
                for={`portfolio-card-${cardIndex}`}
                class="mt-2 inline-block cursor-pointer text-sm font-medium text-primary hover:underline peer-checked:hidden"
              >
                See more
              </label>
              <label
                for={`portfolio-card-${cardIndex}`}
                class="mt-2 hidden cursor-pointer text-sm font-medium text-primary hover:underline peer-checked:inline-block"
              >
                See less
              </label>
            </div>
          ) : (
            <ul class="mt-4 space-y-2.5 text-offset leading-relaxed list-disc pl-5 marker:text-primary">
              {bulletItems.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
          )
        ) : details ? (
          needsDetailsExpandBlock ? (
            <div class="portfolio-card-expand mt-4">
              <input
                type="checkbox"
                id={`portfolio-card-${cardIndex}`}
                class="portfolio-card-expand-input peer sr-only"
              />
              <div class="portfolio-card-expand-shell relative">
                <div class="portfolio-card-expand-inner overflow-hidden max-h-[6rem] sm:max-h-[6.75rem] transition-[max-height] duration-300 ease-out">
                  <p class="text-offset leading-relaxed">{details}</p>
                </div>
                <div
                  class="portfolio-card-expand-fade pointer-events-none absolute inset-x-0 bottom-0 z-10 h-[4.5rem] sm:h-20 transition-opacity duration-200"
                  aria-hidden="true"
                >
                  <div
                    class="absolute inset-0 bg-gradient-to-t from-[var(--color-background-offset)] from-[8%] via-[var(--color-background-offset)]/95 to-transparent"
                  />
                  <span
                    class="relative flex h-full items-end justify-center pb-1 text-xs leading-none text-primary/50"
                  >
                    ⌄
                  </span>
                </div>
              </div>
              <label
                for={`portfolio-card-${cardIndex}`}
                class="mt-2 inline-block cursor-pointer text-sm font-medium text-primary hover:underline peer-checked:hidden"
              >
                See more
              </label>
              <label
                for={`portfolio-card-${cardIndex}`}
                class="mt-2 hidden cursor-pointer text-sm font-medium text-primary hover:underline peer-checked:inline-block"
              >
                See less
              </label>
            </div>
          ) : (
            <p class="mt-4 text-offset leading-relaxed">{details}</p>
          )
        ) : null}
      </>
    ) : (
      <>
        <p class="text-lg font-medium text-secondary pt-2">{sub_title}</p>
        {details && <p class="mt-4 text-offset leading-relaxed">{details}</p>}
      </>
    )
  }
</li>

<style is:global>
  /* Expand inner + hide bottom fade when open (peer/inner are not siblings; mirror Hero tech-stack edge) */
  .portfolio-card-expand-input:checked ~ .portfolio-card-expand-shell .portfolio-card-expand-inner {
    max-height: 120rem;
  }
  .portfolio-card-expand-input:checked ~ .portfolio-card-expand-shell .portfolio-card-expand-fade {
    opacity: 0;
  }
</style>
