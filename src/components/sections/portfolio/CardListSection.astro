---
import CardListItem from './CardListItem.astro';

interface Tech {
  name: string;
  icon: string;
  link: string;
}

interface Item {
  title: string;
  sub_title: string;
  years: string;
  details?: string;
  bullets?: string[];
  company_link?: string;
  company_icon?: string;
  company_logo_url?: string;
  technologies?: Tech[];
  duration?: string;
  country?: string;
  work_mode?: string;
}

const { title, items } = Astro.props;
---

<section class="py-14 bg-background">
  <div class="container mx-auto max-w-4xl px-6">
    <h2 class="text-3xl lg:text-4xl font-semibold text-center mb-12">
        {title}
    </h2>

    <ul class="space-y-8">
      {items.map((item: Item, cardIndex: number) => (
        <CardListItem
          cardIndex={cardIndex}
          title={item.title}
          sub_title={item.sub_title}
          years={item.years}
          details={item?.details}
          bullets={item?.bullets}
          company_link={item?.company_link}
          company_icon={item?.company_icon}
          company_logo_url={item?.company_logo_url}
          technologies={item?.technologies}
          duration={item?.duration}
          country={item?.country}
          work_mode={item?.work_mode}
        />
      ))}
    </ul>
  </div>
</section>
