---
import Header from '../components/layouts/Header.astro';
import Footer from '../components/layouts/Footer.astro';

import '../styles/index.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="h-full" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Akin Gundogdu — Senior Full Stack Software Engineer. 10+ years building scalable APIs, high-performance systems, and web applications. Backend-heavy full stack: Ruby on Rails, TypeScript, Nest.js, React, AWS." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="sitemap" href="/sitemap-index.xml" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="h-full flex flex-col overflow-x-hidden bg-default
		text-default text-base selection:bg-secondary">
		<Header />
		<section class="flex-grow">
			<slot />
		</section>
		<Footer />
	</body>
</html>